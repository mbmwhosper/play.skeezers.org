{
    "name": "play-skeezers-org",
    "version": "2.0.0",
    "description": "Skeezers Arcade v2, a rebuilt browser game, app, and emulator hub for play.skeezers.org.",
    "homepage": "https://play.skeezers.org",
    "bugs": {
        "url": "https://github.com/mbmwhosper/play.skeezers.org/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mbmwhosper/play.skeezers.org.git"
    },
    "license": "MIT",
    "author": "Albert",
    "type": "module",
    "main": "add-game-entry.js",
    "scripts": {
        "add-game": "node add-game-entry.js",
        "build:v2-data": "node scripts/build-v2-data.mjs",
        "build:pages": "npm run build:v2-data && node scripts/prepare-pages-build.mjs",
        "build": "npm run build:v2-data",
        "dev:worker": "wrangler dev -c wrangler.proxy.toml",
        "deploy:worker": "wrangler deploy -c wrangler.proxy.toml",
        "check:worker": "wrangler deploy --dry-run -c wrangler.proxy.toml"
    },
    "dependencies": {
        "@inquirer/prompts": "^7.5.3"
    },
    "devDependencies": {
        "wrangler": "^4.82.2"
    }
}
